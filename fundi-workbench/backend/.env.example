# Google Gemini API Key (primary LLM provider)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini model to use (optional, default: models/gemini-flash-lite-latest)
# GEMINI_MODEL=models/gemini-flash-lite-latest

# OpenRouter API Key (fallback LLM provider, used when Gemini is unavailable)
# Get your API key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter model to use (optional, default: google/gemini-2.0-flash-001)
# See available models: https://openrouter.ai/models
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Environment mode (optional)
# Options: dev | prod
# Default: dev
ENVIRONMENT=dev
